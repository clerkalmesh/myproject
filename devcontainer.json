{
    "name": "Flutter Development",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Dart-Code.flutter",
                "Dart-Code.dart-code",
                "vscjava.vscode-java-pack"
            ],
            "settings": {
                "workbench.colorTheme": "Default Dark Modern",
                "editor.formatOnSave": true
            }
        }
    },
    "remoteUser": "vscode"
}
